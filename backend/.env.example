# MongoDB（多店部署：指向 LZFood 集群；优先于 DBCON 的是 LZFOOD_DBCON）
DBCON=mongodb+srv://user:pass@cluster.example.net/?appName=LZFood
LZFOOD_DBCON=mongodb+srv://user:pass@cluster.example.net/?appName=LZFood

# 开发时可选：未传 X-Store-Slug 时默认解析的店铺 slug（须已在 stores 集合存在）
# DEFAULT_STORE_SLUG=my-first-shop

JWT_SECRET=change-me

# Google Maps / Geocoding 等（服务端：process.env.GoogleGeo；勿将真实 Key 提交到 Git）
# GoogleGeo=

# —— 文件上传（菜品图、门店 Logo、平台广告图等）——
# 本地测试：不要配置 GCS_BUCKET，文件会落在项目 backend/uploads/ 下，由服务 /uploads 提供；
# 若 .env 里已有 GCS_BUCKET 但仍想强制写本地，可设：
# USE_LOCAL_UPLOADS=1
# 生产连 GCS：配置 GCS_BUCKET，且勿设 USE_LOCAL_UPLOADS
# GCS_BUCKET=your-bucket-name
#
# 若用 Nginx 等只反代 /api：须同时反代 /uploads 到本服务，否则广告图、菜品图等无法访问。
# 前后端分域名部署时，前端构建需设置 VITE_API_ORIGIN 指向提供 /uploads 的 API 根 URL（见 frontend/.env.example）。

# —— Twilio 短信（会员储值扣款后通知余额；可选；仅服务端，勿提交真实 Token）——
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# 须配置其一：发信号码（E.164）或 Messaging Service SID
# TWILIO_FROM=+353123456789
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 平台「API 与余额」页低余额提醒（USD）；其它币种默认阈值 5
# TWILIO_LOW_BALANCE_USD=5

# 单店库 → 多店库菜单迁移（migrate-singlestore-menu-to-lzfood.ts），勿提交真实 URI
# IMPORT_SOURCE_DBCON=mongodb+srv://...
# IMPORT_TARGET_STORE_SLUG=tasteofhongkong

# —— 首店种子（npm run seed:store）默认与前端 demo 店一致 ——
SEED_STORE_SLUG=demo
SEED_STORE_DISPLAY_NAME=Taste of Hong Kong
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=owner123
SEED_PLATFORM_USERNAME=lei
SEED_PLATFORM_PASSWORD=45200159
