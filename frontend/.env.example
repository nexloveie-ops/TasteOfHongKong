# 浏览器打开 / 重定向默认店铺（须与 DB 里 stores.slug 一致）
VITE_DEFAULT_STORE_SLUG=demo

# 前端静态站与 API 不同域名时设置（无尾斜杠），用于订单页广告图、上传预览等 /uploads 资源
# 本地开发若 /api 经 Vite 代理仍 404，可取消下行注释，直连后端（须与 backend 端口一致，默认 8080）
# VITE_API_ORIGIN=http://127.0.0.1:8080
# VITE_API_ORIGIN=https://your-api.example.com

# 门店首页地址下方 Google 地图嵌入（Maps Embed API — Place mode）；不配则尝试地址查询嵌入（可能被策略拦截）
# VITE_GOOGLE_MAPS_EMBED_KEY=

# 本地生成二维码 PNG（npm run qr:generate）
QR_BASE_URL=http://localhost:5173
QR_STORE_SLUG=demo
QR_TABLES=5
QR_SEATS=4
